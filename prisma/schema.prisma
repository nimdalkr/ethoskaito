generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TrackedAccount {
  id                    String    @id @default(cuid())
  xUsername             String    @unique
  ethosUserkey          String?
  source                String
  isActive              Boolean   @default(true)
  assignedShardId       Int?
  priorityScore         Int       @default(0)
  nextEligibleAt        DateTime?
  lastCollectedAt       DateTime?
  lastSweepAt           DateTime?
  lastSuccessfulSweepAt DateTime?
  lastSeenTweetId       String?
  lastObservedTweetAt   DateTime?
  lastDiscoveredCount   Int       @default(0)
  lastQueuedCount       Int       @default(0)
  lastProcessedCount    Int       @default(0)
  consecutiveFailures   Int       @default(0)
  lastRunMode           String?
  lastCollectorError    String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  ethosUser             EthosUser? @relation(fields: [ethosUserkey], references: [userkey])

  @@index([isActive, nextEligibleAt])
  @@index([isActive, assignedShardId, lastSuccessfulSweepAt])
}

model EthosUser {
  id                        String   @id @default(cuid())
  userkey                   String   @unique
  profileId                 Int?     @unique
  username                  String?
  displayName               String
  avatarUrl                 String
  description               String?
  score                     Float
  level                     String
  influenceFactor           Float
  influenceFactorPercentile Float
  humanVerificationStatus   String?
  validatorNftCount         Int      @default(0)
  xpTotal                   Float    @default(0)
  xpStreakDays              Int      @default(0)
  reviewPositive            Int      @default(0)
  reviewNeutral             Int      @default(0)
  reviewNegative            Int      @default(0)
  vouchGivenCount           Int      @default(0)
  vouchReceivedCount        Int      @default(0)
  trustComposite            Float
  trustTier                 String
  raw                       Json
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  tweets                    Tweet[]
  trackedAccounts           TrackedAccount[]
}

model CollectorRun {
  id                String   @id @default(cuid())
  mode              String
  status            String
  shardId           Int?
  shardCount        Int?
  selectedAccounts  Int      @default(0)
  processedAccounts Int      @default(0)
  discoveredTweets  Int      @default(0)
  queuedTweets      Int      @default(0)
  ingestedTweets    Int      @default(0)
  errorCount        Int      @default(0)
  startedAt         DateTime @default(now())
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([mode, startedAt])
}

model CollectorShardState {
  id                String   @id @default(cuid())
  mode              String
  shardId           Int
  shardCount        Int
  status            String
  lastRunId         String?
  lastStartedAt     DateTime?
  lastCompletedAt   DateTime?
  accountsTotal     Int      @default(0)
  accountsProcessed Int      @default(0)
  errorCount        Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([mode, shardId, shardCount])
  @@index([mode, updatedAt])
}

model WorkerLease {
  id          String   @id @default(cuid())
  workerType  String   @unique
  holderId    String
  acquiredAt  DateTime @default(now())
  heartbeatAt DateTime @default(now())
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workerType, expiresAt])
}

model Tweet {
  id             String        @id @default(cuid())
  tweetId        String        @unique
  url            String
  xUsername      String
  authorName     String
  text           String
  createdAt      DateTime
  observedAt     DateTime
  source         String
  likeCount      Int           @default(0)
  repostCount    Int           @default(0)
  replyCount     Int           @default(0)
  quoteCount     Int           @default(0)
  raw            Json
  ethosUserId    String?
  ethosUser      EthosUser?    @relation(fields: [ethosUserId], references: [id])
  mentions       ProjectMention[]
  insertedAt     DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([xUsername, createdAt])
}

model Project {
  id            String          @id @default(cuid())
  projectId     Int             @unique
  userkey       String
  name          String
  username      String?
  description   String?
  totalVotes    Int             @default(0)
  uniqueVoters  Int             @default(0)
  bullishVotes  Int             @default(0)
  bearishVotes  Int             @default(0)
  commentCount  Int             @default(0)
  categories    Json
  chains        Json
  raw           Json
  activities    ProjectActivity[]
  aliases       ProjectAlias[]
  mentions      ProjectMention[]
  marketMappings ProjectMarketMapping[]
  outcomes      ProjectOutcome[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model ProjectAlias {
  id        String   @id @default(cuid())
  projectId String
  alias     String
  normalizedAlias String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, normalizedAlias])
  @@index([normalizedAlias])
}

model ProjectMention {
  id                    String   @id @default(cuid())
  tweetId               String
  projectId             String
  authorUserkey         String
  authorTier            String
  authorComposite       Float
  weight                Int
  isFirstTrackedMention Boolean  @default(false)
  mentionedAt           DateTime
  createdAt             DateTime @default(now())
  tweet                 Tweet    @relation(fields: [tweetId], references: [id], onDelete: Cascade)
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([tweetId, projectId])
  @@index([projectId, mentionedAt])
}

model ProjectActivity {
  id                 String   @id @default(cuid())
  projectId          String
  externalActivityId String
  type               String
  timestamp          DateTime
  sourceCreatedAt    DateTime?
  sentiment          String?
  comment            String?
  description        String?
  authorUserkey      String?
  authorProfileId    Int?
  authorUsername     String?
  authorDisplayName  String?
  subjectUserkey     String?
  subjectProfileId   Int?
  subjectUsername    String?
  subjectDisplayName String?
  upvotes            Int      @default(0)
  downvotes          Int      @default(0)
  replyCount         Int      @default(0)
  llmQualityScore    Float?
  isSpam             Boolean  @default(false)
  link               String?
  raw                Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, externalActivityId, type])
  @@index([projectId, timestamp])
  @@index([timestamp])
}

model ProjectOutcome {
  id            String   @id @default(cuid())
  projectId     String
  source        String
  symbol        String
  firstPriceAt  DateTime?
  latestPriceAt DateTime?
  return1d      Float?
  return7d      Float?
  return30d     Float?
  raw           Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, source, symbol])
}

model ProjectMarketMapping {
  id        String   @id @default(cuid())
  projectId String
  source    String
  symbol    String
  baseCurrency String @default("usd")
  isPrimary Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, source, symbol, baseCurrency])
}
